# --- HTTP ---
HOST=0.0.0.0
PORT=8080

# --- Polling ---
# Період опитування збору, секунди (вимога: 1с)
POLL_INTERVAL=1.0
# Скільки зборів опитувати паралельно за один тік
POLL_CONCURRENCY=8
HTTP_TIMEOUT=15

# --- Database (SQLite) ---
DB_PATH=bank_watcher.db

# --- Доступ до фронта/API (сесійний логін) ---
# Порожні значення = вхід вимкнено (усе deny). Згенеруй сильний пароль.
AUTH_USER=
AUTH_PASSWORD=
SESSION_TTL_HOURS=168

# --- Колбеки до ncP2P (вихідні, bank-watcher → ncP2P) ---
# HMAC-SHA256 над сирим JSON-тілом; узгодити секрет із ncP2P.
CALLBACK_SECRET=
CALLBACK_MAX_ATTEMPTS=10
CALLBACK_TIMEOUT=15

# --- Машинна авторизація вхідних (ncP2P → bank-watcher) ---
# HMAC-SHA256 над сирим тілом, заголовок X-Signature. Порожній = лише сесійний логін.
INBOUND_SECRET=

# --- NordVPN (пошук робочого екзиту; monobank 403'ить частину VPN-IP) ---
# На локальній машині лишай false. На сервері: true + split-tunnel (allowlist портів 22,8080).
VPN_ENABLED=false
VPN_COUNTRIES=Netherlands,Germany,Poland,Sweden,France
VPN_PROBE_JAR=4xPDzE2tmw       # публічна банка для перевірки екзиту
VPN_CHECK_SECONDS=120          # період ре-проби поточного екзиту
VPN_MAX_ATTEMPTS=8             # скільки екзитів перебрати в пошуку робочого
VPN_SETTLE_SECONDS=3           # пауза після connect перед пробою
VPN_FALLBACK_DIRECT=true       # нема робочого екзиту → прямий IP сервера
