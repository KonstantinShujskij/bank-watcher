# --- HTTP ---
HOST=0.0.0.0
PORT=8080

# --- Polling ---
# Період опитування збору, секунди (вимога: 1с)
POLL_INTERVAL=1.0
# Скільки зборів опитувати паралельно за один тік
POLL_CONCURRENCY=8
HTTP_TIMEOUT=15

# --- Database (SQLite) ---
DB_PATH=bank_watcher.db

# --- Доступ до фронта/API (сесійний логін) ---
# Порожні значення = вхід вимкнено (усе deny). Згенеруй сильний пароль.
AUTH_USER=
AUTH_PASSWORD=
SESSION_TTL_HOURS=168

# --- Колбеки до ncP2P ---
# HMAC-SHA256 над сирим JSON-тілом запиту; узгодити секрет із ncP2P пізніше.
CALLBACK_SECRET=
CALLBACK_MAX_ATTEMPTS=10
CALLBACK_TIMEOUT=15

# --- NordVPN (ротація вихідного IP) ---
# На локальній машині лишай false. На сервері: true + split-tunnel для нашого порту.
VPN_ENABLED=false
VPN_ROTATE_SECONDS=300
VPN_COUNTRIES=Ukraine,Poland,Germany
